<?xml version="1.0" encoding="utf-8"?>
<!-- Analog-mixer style level meter: green (safe) → orange (hot) → red (clip).
     The gradient is anchored across the full track; the clip reveals more of
     it as the level rises, so the top of a high reading shows orange/red. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <solid android:color="#1a1a1a" />
            <stroke android:width="1dp" android:color="#333333" />
            <corners android:radius="2dp" />
        </shape>
    </item>

    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <gradient
                    android:startColor="#00ff00"
                    android:centerColor="#ff9900"
                    android:endColor="#ff0000"
                    android:type="linear"
                    android:angle="0" />
                <corners android:radius="2dp" />
            </shape>
        </clip>
    </item>

</layer-list>
